<Window x:Class="DevilGuard.Setup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Devil-Guard Setup" Height="500" Width="760"
        MinHeight="460" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        Background="#111820" Foreground="#FFF8E7"
        Icon="devil-guard.ico"
        Loaded="Window_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="DEVIL-GUARD SETUP" FontSize="26" FontWeight="Bold" Foreground="#FFD449"/>
            <TextBlock Text="Install and maintain the Sentinel Windows service" Opacity="0.85"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#1C2833" BorderBrush="#DBA900" BorderThickness="1" CornerRadius="8" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Sentinel status" FontWeight="SemiBold"/>
                <TextBlock x:Name="ServiceStatusText" Grid.Column="1" Text="Checking…" Foreground="#FFD449"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="#1C2833" CornerRadius="8" Padding="18">
            <StackPanel>
                <TextBlock Text="Service controls" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Margin="0,8,0,18" TextWrapping="Wrap" Opacity="0.8"
                           Text="Installation and removal require administrator approval. The setup app launches the included PowerShell scripts with Windows elevation."/>
                <TextBlock Text="Gatekeeper URL" FontWeight="SemiBold"/>
                <TextBox x:Name="GatekeeperUrlTextBox" Margin="0,6,0,10" Height="30" VerticalContentAlignment="Center"/>
                <TextBlock Text="Gatekeeper token" FontWeight="SemiBold"/>
                <PasswordBox x:Name="GatekeeperTokenBox" Margin="0,6,0,6" Height="30"/>
                <TextBlock Margin="0,0,0,14" Opacity="0.75" TextWrapping="Wrap"
                           Text="These values are optional. When provided during install/update, they are stored as machine environment variables used by Sentinel."/>
                <WrapPanel>
                    <Button Content="Install or update service" Width="180" Margin="0,0,10,10" Padding="10,7" Click="Install_Click"/>
                    <Button Content="Remove service" Width="140" Margin="0,0,10,10" Padding="10,7" Click="Uninstall_Click"/>
                    <Button Content="Open program folder" Width="160" Margin="0,0,10,10" Padding="10,7" Click="OpenFolder_Click"/>
                </WrapPanel>
                <TextBlock x:Name="MessageText" Margin="0,14,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="6" LastChildFill="False">
            <Button DockPanel.Dock="Right" Content="Close" Width="90" Margin="10,0,0,0" Padding="10,6" Click="Close_Click"/>
            <Button DockPanel.Dock="Right" Content="Refresh" Width="90" Padding="10,6" Click="Refresh_Click"/>
        </DockPanel>
    </Grid>
</Window>
