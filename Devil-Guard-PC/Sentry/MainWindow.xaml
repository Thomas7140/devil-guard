<Window x:Class="DevilGuard.Sentry.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Devil-Guard Sentry"
        Height="430" Width="720" MinHeight="400" MinWidth="650"
        WindowStartupLocation="CenterScreen"
        Background="#111820" Foreground="#FFF8E7"
        Icon="devil-guard.ico"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="DEVIL-GUARD" FontSize="28" FontWeight="Bold" Foreground="#FFD449"/>
            <TextBlock Text="Sentry client · .NET 10 · Windows desktop" FontSize="14" Opacity="0.85"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#1C2833" BorderBrush="#DBA900" BorderThickness="1" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Client status" FontWeight="SemiBold"/>
                <TextBlock x:Name="ClientStatusText" Grid.Column="1" Text="Starting…" Foreground="#FFD449"/>

                <TextBlock Grid.Row="2" Text="Operating system" FontWeight="SemiBold"/>
                <TextBlock x:Name="OperatingSystemText" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="4" Text="Runtime" FontWeight="SemiBold"/>
                <TextBlock x:Name="RuntimeText" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="6" Text="Delta Force BHD" FontWeight="SemiBold"/>
                <TextBlock x:Name="GameStatusText" Grid.Row="6" Grid.Column="1"/>

                <TextBlock Grid.Row="8" Text="Last refresh" FontWeight="SemiBold"/>
                <TextBlock x:Name="LastRefreshText" Grid.Row="8" Grid.Column="1"/>
            </Grid>
        </Border>

        <DockPanel Grid.Row="4" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Text="Devil-Guard 1.0.0" Opacity="0.7"/>
            <Button DockPanel.Dock="Right" Content="Close" Width="90" Margin="10,0,0,0" Padding="10,6" Click="Close_Click"/>
            <Button DockPanel.Dock="Right" Content="Minimise" Width="90" Margin="10,0,0,0" Padding="10,6" Click="Minimise_Click"/>
            <Button DockPanel.Dock="Right" Content="Open logs" Width="100" Margin="10,0,0,0" Padding="10,6" Click="OpenLogs_Click"/>
            <Button DockPanel.Dock="Right" Content="Refresh" Width="90" Padding="10,6" Click="Refresh_Click"/>
        </DockPanel>
    </Grid>
</Window>
