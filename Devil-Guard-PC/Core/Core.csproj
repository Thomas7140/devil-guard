    <PackageReference Include="System.ServiceProcess.ServiceController" Version="10.0.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Logging\Logging.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="Docs\HWID.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
