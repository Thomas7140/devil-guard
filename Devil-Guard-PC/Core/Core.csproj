    <AssemblyName>DevilGuard.Core</AssemblyName>
    <RootNamespace>DevilGuard.Core</RootNamespace>
    <Product>Devil-Guard Core</Product>
    <Description>Core Windows and game integration services for Devil-Guard.</Description>
    <UseWPF>true</UseWPF>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="System.Drawing.Common" Version="10.0.0" />
    <PackageReference Include="System.Management" Version="10.0.0" />
