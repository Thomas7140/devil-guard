<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="DevilGuardYellow">#FFDBA900</Color>
    <Color x:Key="DevilGuardLightYellow">#FFFFD449</Color>
    <Color x:Key="DevilGuardBlue">#FF1C2833</Color>
    <Color x:Key="DevilGuardDarkBlue">#FF111820</Color>
    <Color x:Key="DevilGuardCream">#FFFFF8E7</Color>

    <SolidColorBrush x:Key="DevilGuardYellowBrush" Color="{StaticResource DevilGuardYellow}"/>
    <SolidColorBrush x:Key="DevilGuardLightYellowBrush" Color="{StaticResource DevilGuardLightYellow}"/>
    <SolidColorBrush x:Key="DevilGuardBlueBrush" Color="{StaticResource DevilGuardBlue}"/>
    <SolidColorBrush x:Key="DevilGuardDarkBlueBrush" Color="{StaticResource DevilGuardDarkBlue}"/>
    <SolidColorBrush x:Key="DevilGuardCreamBrush" Color="{StaticResource DevilGuardCream}"/>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource DevilGuardYellowBrush}"/>
        <Setter Property="Foreground" Value="#FF111820"/>
        <Setter Property="BorderBrush" Value="{StaticResource DevilGuardLightYellowBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource DevilGuardLightYellowBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Opacity" Value="0.78"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
