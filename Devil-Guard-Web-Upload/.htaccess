Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
RewriteEngine On

# Never expose application code, configuration, SQL, maintenance scripts, logs, or deployment files.
RewriteRule ^(?:src|config|database|scripts|storage|deploy)(?:/|$) - [F,L,NC]
RewriteRule ^(?:README(?:\.md)?|UPLOAD-INSTRUCTIONS\.txt|SCAN-REPORT\.txt|\.gitignore)$ - [F,L,NC]

# Friendly application routes.
RewriteRule ^api/attestation/?(.*)$ api/index.php?route=attestation/$1 [QSA,L]
RewriteRule ^api/v1/?(.*)$ api/index.php?route=$1 [QSA,L]
RewriteRule ^admin/?$ admin/index.php [QSA,L]
</IfModule>


<Files "uid.php">
Require all denied
</Files>

<FilesMatch "(^\.|\.(?:env|ini|log|sql|bak|dist|example|md)$)">
Require all denied
</FilesMatch>

<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "DENY"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>
