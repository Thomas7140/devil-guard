APP_NAME=Devil-Guard
APP_ENV=production
APP_DEBUG=false
APP_URL=https://devil-guard.devilishservices.com
APP_KEY=replace-with-64-random-hex-characters
APP_TIMEZONE=Australia/Hobart
SESSION_NAME=devil_guard_session
ALLOW_REGISTRATION=false
TOKEN_TTL_HOURS=168

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=devil_guard
DB_USER=devil_guard
DB_PASS=change-this-password

# Comma-separated browser origins. Desktop clients do not require CORS.
CORS_ALLOWED_ORIGINS=https://devil-guard.devilishservices.com
